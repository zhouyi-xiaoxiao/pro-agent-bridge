{
  "name": "codexpro",
  "version": "0.28.5",
  "description": "A local MCP/App SDK-style connector that lets ChatGPT inspect, edit, and hand off work to Codex inside a local dev workspace.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zhouyi-xiaoxiao/codexpro-extended-bridge.git"
  },
  "bugs": {
    "url": "https://github.com/zhouyi-xiaoxiao/codexpro-extended-bridge/issues"
  },
  "homepage": "https://github.com/zhouyi-xiaoxiao/codexpro-extended-bridge#readme",
  "keywords": [
    "mcp",
    "chatgpt",
    "codex",
    "apps-sdk",
    "codexpro",
    "local-development",
    "cloudflare-tunnel",
    "ngrok"
  ],
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "docs",
    "scripts",
    "README.md",
    "README_ZH.md",
    "PUBLIC_LAUNCH_CHECKLIST.md",
    "DOMAIN_SETUP.md",
    "LICENSE",
    "SECURITY.md",
    "CONTRIBUTING.md",
    "FAQ.md",
    "FAQ_ZH.md",
    "CHANGELOG.md",
    "CHATGPT_PROMPT.md",
    "CODEX_PROMPT.md",
    "EXTENDED_PRO_CLAUDE_BRIDGE.md",
    "CHATGPT_PRO_REVIEW_PACKET.md",
    "TECHNICAL_ARCHITECTURE.md",
    "SECOND_ROUND_AUDIT.md",
    "AGENTS.example.md",
    "config.example.env"
  ],
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "codexpro": "scripts/codexpro.mjs",
    "codexpro-claude-handoff": "scripts/claude-handoff.mjs",
    "codexpro-capture-chatgpt": "scripts/chatgpt-scroll-capture.mjs",
    "codexpro-mcp": "dist/stdio.js",
    "codexpro-mcp-http": "dist/http.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "npm run build",
    "start": "node dist/stdio.js",
    "start:stdio": "node dist/stdio.js",
    "start:http": "node dist/http.js",
    "dev:stdio": "tsx src/stdio.ts",
    "dev:http": "tsx src/http.ts",
    "smoke": "node scripts/smoke.mjs && node scripts/http-smoke.mjs && node scripts/pro-smoke.mjs && node scripts/doctor-smoke.mjs && node scripts/settings-smoke.mjs && node scripts/execute-handoff-smoke.mjs",
    "smoke:chatgpt-capture": "node scripts/chatgpt-capture-smoke.mjs",
    "doctor": "node scripts/codexpro.mjs doctor",
    "connect": "node scripts/codexpro.mjs",
    "connect:setup": "node scripts/codexpro.mjs setup",
    "connect:local": "node scripts/codexpro.mjs --tunnel none",
    "connect:cloudflare": "node scripts/codexpro.mjs --tunnel cloudflare",
    "connect:chatgpt": "node scripts/codexpro.mjs --tunnel cloudflare",
    "connect:stable": "node scripts/codexpro.mjs --tunnel cloudflare-named",
    "connect:ngrok": "node scripts/codexpro.mjs ngrok",
    "pro:bundle": "node scripts/pro-bundle.mjs",
    "pro:apply": "node scripts/pro-apply.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.4",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "minimatch": "^10.0.1",
    "ws": "^8.21.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^24.0.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
